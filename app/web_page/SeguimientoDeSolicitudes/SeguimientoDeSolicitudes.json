    "agregarEstatusSolicitudVacaciones" : {
      "type" : "expression",
      "value" : [
        "if ($data.hasOwnProperty('solicitudVacaciones') && $data.solicitudVacaciones) {\r",
        "    for (let solicitud of $data.solicitudVacaciones) {\r",
        "\r",
        "        if (solicitud.estaAprobado === true) {\r",
        "            solicitud.esAprobadaEtiqueta = \"Aprobada\";\r",
        "        } else if (solicitud.estaAprobado === false) {\r",
        "            solicitud.esAprobadaEtiqueta = \"Rechazada\";\r",
        "        } else {\r",
        "            solicitud.esAprobadaEtiqueta = \"En curso\";\r",
        "        }\r",
        "\r",
        "    }\r",
        "}\r",
        "\r",
        "return $data.solicitudVacaciones;"
      ],
